---
import { getCollection } from 'astro:content';

const entries = (await getCollection('features')).filter(e => e.data.type === 'rule');
---

<section class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-4">
        Smart Checkout Control
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        Set the rules. Your checkout enforces them automatically.
      </p>
    </div>

    <!-- 3-Column Grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {entries.map((entry) => (
        <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <!-- Mockup Area -->
          <div class="bg-gray-50 p-5 border-b border-gray-200">
            <div class="bg-white rounded-xl border border-gray-200 p-4">
              <!-- Mini checkout mockup -->
              <div class="space-y-2 mb-3">
                <div class="h-1.5 bg-gray-100 rounded w-3/4"></div>
                <div class="h-1.5 bg-gray-100 rounded w-1/2"></div>
                <div class="grid grid-cols-2 gap-1.5">
                  <div class="h-5 bg-gray-50 rounded"></div>
                  <div class="h-5 bg-gray-50 rounded"></div>
                </div>
              </div>
              <!-- Rule message -->
              <div class={`rounded-lg p-2.5 text-[10px] font-medium ${
                entry.data.mockupType === 'warning' ? 'bg-red-50 text-red-600 border border-red-200' :
                entry.data.mockupType === 'success' ? 'bg-green-50 text-green-600 border border-green-200' :
                'bg-blue-50 text-blue-600 border border-blue-200'
              }`}>
                {entry.data.mockupLabel}
              </div>
            </div>
          </div>

          <!-- Card Content -->
          <div class="p-6 sm:p-8">
            <div class="w-10 h-10 bg-mint-500/10 rounded-xl flex items-center justify-center mb-4">
              <Fragment set:html={entry.data.icon} />
            </div>

            <h3 class="font-heading font-semibold text-lg text-gray-900 mb-2">
              {entry.data.title}
            </h3>

            <p class="text-gray-500 text-sm leading-relaxed mb-5">
              {entry.data.description}
            </p>

            <a href={`/features/${entry.id}`} class="inline-flex items-center gap-1 text-mint-600 hover:text-mint-700 font-medium text-sm transition-colors">
              Learn More
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
