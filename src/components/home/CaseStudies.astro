---
const studies = [
  {
    store: "Headphone Zone",
    slug: "headphone-zone",
    action: "Added trust badges, customer reviews, and gift message fields to their checkout",
    result: "Customers feel more confident completing purchases with visible trust signals at checkout.",
    tags: ["Trust Badges", "Custom Fields", "Reviews"],
  },
  {
    store: "Lumebox",
    slug: "lumebox",
    action: "Set up checkout validation rules to prevent incomplete orders",
    result: "Reduced support tickets from incomplete orders and improved fulfillment accuracy.",
    tags: ["Validation Rules", "Checkout Rules"],
  },
  {
    store: "Store Example",
    slug: "store-example",
    action: "Implemented checkout upsells and branded banners to increase average order value",
    result: "Saw measurable improvement in AOV with targeted product recommendations at checkout.",
    tags: ["Upsells", "Banners", "AOV"],
  },
];
---

<section class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-4">
        Results from real stores
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        See how Shopify Plus merchants are using Checkout Ninja to improve their checkout experience and drive real results.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-10">
      {studies.map((study) => (
        <a href={`/case-studies/${study.slug}`} class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:border-mint-500/30 hover:shadow-lg transition-all flex flex-col">
          <!-- Store header with logo placeholder -->
          <div class="bg-gray-900 px-6 py-8 text-center">
            <div class="w-12 h-12 bg-white/10 rounded-xl mx-auto mb-3 flex items-center justify-center">
              <span class="text-white font-heading font-bold text-lg">{study.store.charAt(0)}</span>
            </div>
            <h3 class="font-heading font-semibold text-white text-lg">{study.store}</h3>
          </div>

          <!-- Content -->
          <div class="p-6 flex-1 flex flex-col">
            <p class="text-gray-700 font-medium text-sm mb-3">{study.action}</p>
            <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1">"{study.result}"</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-4">
              {study.tags.map((tag) => (
                <span class="text-xs px-2.5 py-1 bg-mint-500/10 text-mint-600 rounded-full font-medium">{tag}</span>
              ))}
            </div>

            <!-- Read link -->
            <span class="text-mint-600 font-medium text-sm group-hover:text-mint-700 transition-colors inline-flex items-center gap-1">
              Read case study
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center">
      <a href="/case-studies" class="inline-flex items-center gap-2 px-6 py-3 bg-white border border-gray-200 rounded-full text-gray-700 font-medium text-sm hover:border-gray-300 hover:shadow-sm transition-all">
        View all case studies
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
