---

<section class="bg-gray-50 border-y border-gray-200 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x lg:divide-gray-200">
      <!-- 5.0 Star Rating -->
      <div class="text-center lg:px-6">
        <div class="flex items-center justify-center gap-1 mb-2">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <div class="font-heading font-bold text-2xl text-gray-900">5.0</div>
        <div class="text-gray-500 text-sm">on Shopify App Store</div>
      </div>

      <!-- Built for Shopify Plus -->
      <div class="text-center lg:px-6 flex flex-col items-center justify-center">
        <div class="w-10 h-10 bg-mint-500/10 rounded-xl flex items-center justify-center mb-2">
          <svg class="w-6 h-6 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
        </div>
        <div class="font-heading font-bold text-lg text-gray-900">Built for Shopify Plus</div>
      </div>

      <!-- Testimonial -->
      <div class="text-center lg:px-6">
        <p class="text-gray-600 text-sm italic leading-relaxed mb-2">
          "Fantastic app, highly recommended. A must have for all your Shopify checkout needs!"
        </p>
        <div class="text-gray-400 text-xs font-medium">— Headphone Zone India</div>
      </div>

      <!-- Trusted Globally -->
      <div class="text-center lg:px-6 flex flex-col items-center justify-center">
        <div class="font-heading font-bold text-2xl text-mint-600 mb-1">15+</div>
        <div class="text-gray-500 text-sm">Countries trust Checkout Ninja</div>
      </div>
    </div>
  </div>
</section>
