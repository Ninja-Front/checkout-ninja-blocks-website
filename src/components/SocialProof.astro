---
const stats = [
  { value: "2,000+", label: "Shopify Stores" },
  { value: "15M+", label: "Checkouts Processed" },
  { value: "32%", label: "Avg Conversion Lift" },
  { value: "4.9", label: "Star Rating" },
];

const testimonials = [
  {
    quote: "We saw a 28% increase in checkout completions within the first week. The one-page checkout alone was a game changer.",
    name: "Sarah Chen",
    role: "Founder, Lumière Beauty",
    stars: 5,
  },
  {
    quote: "The smart upsell feature paid for itself on day one. Our AOV jumped by $12 per order without any extra effort.",
    name: "Marcus Thompson",
    role: "CEO, UrbanGear Co",
    stars: 5,
  },
  {
    quote: "Finally a checkout app that actually looks good on mobile. Our mobile conversion rate went from 1.2% to 3.8%.",
    name: "Jessica Park",
    role: "Head of E-commerce, FreshKits",
    stars: 5,
  },
];
---

<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Stats Bar -->
    <div class="bg-navy-900 border border-navy-700 rounded-2xl p-8 mb-12 lg:mb-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="font-heading font-bold text-3xl sm:text-4xl text-mint-400 mb-1">{stat.value}</div>
            <div class="text-slate-400 text-sm">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Testimonials -->
    <div class="text-center mb-12">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-white mb-4">
        Loved by Shopify Merchants
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-navy-800 border border-navy-700 rounded-2xl p-8">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-5 h-5 text-mint-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-slate-200 text-sm leading-relaxed mb-6">"{t.quote}"</p>
          <div>
            <div class="text-white font-semibold text-sm">{t.name}</div>
            <div class="text-slate-400 text-xs">{t.role}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
