---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const shopifyAppStoreUrl = "https://apps.shopify.com/checkout-ninja-blocks";
---

<BaseLayout
  title="About — Checkout Ninja by Nex App Studio | Shopify Plus Checkout App"
  description="Checkout Ninja is built by Nex App Studio in Sharjah, UAE. Learn why we built the most flexible checkout customization app for Shopify Plus."
>
  <Navbar />
  <main class="pt-16">
    <!-- Section 1: Hero -->
    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-gray-900 mb-6">
          Built by Merchants, for Merchants
        </h1>
        <p class="text-gray-500 text-lg sm:text-xl max-w-2xl mx-auto">
          Checkout Ninja is made by Nex App Studio — a team that understands the checkout experience because we've lived it from the merchant's side.
        </p>
      </div>
    </section>

    <!-- Section 2: The Story -->
    <section class="py-16 lg:py-24 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-8 text-center">
          Why We Built Checkout Ninja
        </h2>
        <div class="space-y-6 text-gray-600 text-base sm:text-lg leading-relaxed">
          <p>
            We started as Shopify merchants ourselves, and we kept running into the same wall: the checkout was the most important part of the buying journey, but it was the hardest to customize. Every tweak required a developer, every change took days, and the options were limited.
          </p>
          <p>
            So we built Checkout Ninja — a no-code toolkit that gives Shopify Plus merchants full control over their checkout. Hide payment methods based on cart contents, add trust badges, show custom banners, validate fields, reorder shipping options — all without writing a single line of code.
          </p>
          <p>
            Since launching in November 2023, we've grown to serve merchants in over 15 countries, with a library of 24 checkout blocks and a perfect 5.0-star rating on the Shopify App Store. Every week, we ship improvements based on real merchant feedback.
          </p>
          <p>
            What drives us is simple: merchants should own their checkout experience. No gatekeepers, no complex code, no waiting on developers. Just the tools you need, ready when you are.
          </p>
        </div>
      </div>
    </section>

    <!-- Section 3: What We Stand For -->
    <section class="py-16 lg:py-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-12 text-center">
          What We Stand For
        </h2>
        <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
          <!-- Merchants First -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 text-center">
            <div class="w-12 h-12 bg-mint-500/10 rounded-xl flex items-center justify-center mx-auto mb-5">
              <svg class="w-6 h-6 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-lg text-gray-900 mb-2">Merchants First</h3>
            <p class="text-gray-500 text-sm">
              Every feature we build starts with a real merchant need. Your feedback shapes our roadmap, not the other way around.
            </p>
          </div>

          <!-- No-Code, No Limits -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 text-center">
            <div class="w-12 h-12 bg-mint-500/10 rounded-xl flex items-center justify-center mx-auto mb-5">
              <svg class="w-6 h-6 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-lg text-gray-900 mb-2">No-Code, No Limits</h3>
            <p class="text-gray-500 text-sm">
              Powerful checkout customization shouldn't require a developer. We make complex things simple so you can move fast.
            </p>
          </div>

          <!-- Support That Cares -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 text-center">
            <div class="w-12 h-12 bg-mint-500/10 rounded-xl flex items-center justify-center mx-auto mb-5">
              <svg class="w-6 h-6 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-lg text-gray-900 mb-2">Support That Cares</h3>
            <p class="text-gray-500 text-sm">
              We respond fast, we listen carefully, and we go the extra mile. Your success with Checkout Ninja is our success.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: By the Numbers -->
    <section class="py-16 lg:py-20 bg-gray-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12 text-center">
          <div>
            <p class="font-heading font-bold text-4xl sm:text-5xl text-mint-500 mb-2">5.0</p>
            <p class="text-gray-500 text-sm font-medium">Star Rating</p>
          </div>
          <div>
            <p class="font-heading font-bold text-4xl sm:text-5xl text-mint-500 mb-2">24</p>
            <p class="text-gray-500 text-sm font-medium">Checkout Blocks</p>
          </div>
          <div>
            <p class="font-heading font-bold text-4xl sm:text-5xl text-mint-500 mb-2">15+</p>
            <p class="text-gray-500 text-sm font-medium">Countries</p>
          </div>
          <div>
            <p class="font-heading font-bold text-4xl sm:text-5xl text-mint-500 mb-2">2023</p>
            <p class="text-gray-500 text-sm font-medium">Since Launch</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 5: Company Info -->
    <section class="py-16 lg:py-24">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-8">
          About Nex App Studio
        </h2>
        <div class="space-y-4 text-gray-600 text-base sm:text-lg">
          <p>
            <span class="font-semibold text-gray-900">Nex App Studio</span> — Sharjah, United Arab Emirates
          </p>
          <p>
            <a href="https://nexappstudio.com" target="_blank" rel="noopener noreferrer" class="text-mint-500 hover:text-mint-600 underline">nexappstudio.com</a>
          </p>
          <p>
            <a href={shopifyAppStoreUrl} target="_blank" rel="noopener noreferrer" class="text-mint-500 hover:text-mint-600 underline">View on Shopify App Store</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Section 6: Bottom CTA -->
    <section class="py-16 lg:py-24 relative overflow-hidden">
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-[800px] h-[400px] bg-mint-500/5 rounded-full blur-3xl"></div>
      </div>

      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
        <h2 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-gray-900 mb-6">
          Ready to See What Checkout Ninja Can Do?
        </h2>
        <p class="text-gray-500 text-lg sm:text-xl mb-10 max-w-2xl mx-auto">
          Install Checkout Ninja and take full control of your Shopify Plus checkout today.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={shopifyAppStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-10 py-4 bg-mint-500 hover:bg-mint-600 text-white font-bold rounded-full transition-colors text-base"
          >
            Install on Shopify
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="/contact" class="inline-flex items-center justify-center px-10 py-4 border border-gray-300 hover:border-gray-400 text-gray-700 font-medium rounded-full transition-colors text-base">
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
