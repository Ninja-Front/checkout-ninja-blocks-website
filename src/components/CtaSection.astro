---

<section id="cta" class="py-16 lg:py-24 relative overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-[800px] h-[400px] bg-mint-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <h2 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-gray-900 mb-6">
      Ready to Boost Your Checkout Conversions?
    </h2>
    <p class="text-gray-500 text-lg sm:text-xl mb-10 max-w-2xl mx-auto">
      Join 2,000+ Shopify stores already using Checkout Ninja to turn more visitors into paying customers.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#" class="inline-flex items-center justify-center px-10 py-4 bg-mint-500 hover:bg-mint-600 text-white font-bold rounded-full transition-colors text-base">
        Install Free on Shopify
        <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a href="#" class="inline-flex items-center justify-center px-10 py-4 border border-gray-300 hover:border-gray-400 text-gray-700 font-medium rounded-full transition-colors text-base">
        Book a Demo
      </a>
    </div>

    <p class="text-gray-400 text-sm mt-6">Free to install. No credit card required.</p>
  </div>
</section>
