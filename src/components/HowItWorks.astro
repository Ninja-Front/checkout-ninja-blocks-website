---
const steps = [
  {
    number: "01",
    title: "Install",
    description: "One-click install from the Shopify App Store. No code, no developers, no headaches.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>`,
  },
  {
    number: "02",
    title: "Customize",
    description: "Use our drag-and-drop editor to match your brand. Pick colors, layouts, and upsell offers.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" /></svg>`,
  },
  {
    number: "03",
    title: "Profit",
    description: "Watch your conversion rate climb in real-time as customers breeze through your optimized checkout.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>`,
  },
];
---

<section id="how-it-works" class="py-16 lg:py-24 bg-navy-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-white mb-4">
        Up and Running in Minutes
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        No developers needed. No complex setup. Just install, customize, and start converting.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 relative">
      <!-- Connecting line (desktop only) -->
      <div class="hidden md:block absolute top-24 left-1/6 right-1/6 h-px border-t-2 border-dashed border-navy-600"></div>

      {steps.map((step) => (
        <div class="relative text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-mint-500/10 border-2 border-mint-500/30 rounded-2xl text-mint-400 mb-6 relative z-10 bg-navy-950" set:html={step.icon} />
          <div class="text-mint-400 font-heading font-bold text-sm mb-2">{step.number}</div>
          <h3 class="font-heading font-semibold text-xl text-white mb-3">{step.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
