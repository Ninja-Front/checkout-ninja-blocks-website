---

---

<section class="relative pt-28 pb-16 overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-mint-500/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Text Content -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-mint-500/10 border border-mint-500/20 rounded-full mb-6">
        <span class="w-2 h-2 bg-mint-500 rounded-full animate-pulse"></span>
        <span class="text-mint-600 text-sm font-medium">24 Checkout Blocks Available</span>
      </div>

      <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6 text-gray-900">
        Everything You Need to Build the
        <span class="text-mint-500"> Perfect Checkout</span>
      </h1>

      <p class="text-gray-500 text-lg sm:text-xl leading-relaxed mb-10 max-w-2xl mx-auto">
        24 drag-and-drop blocks, smart rules, and pre-built templates — customize your Shopify Plus checkout without writing a single line of code
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#" class="inline-flex items-center justify-center px-8 py-3.5 bg-mint-500 hover:bg-mint-600 text-white font-semibold rounded-full transition-colors text-base">
          Install on Shopify
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="/pricing" class="inline-flex items-center justify-center px-8 py-3.5 border border-gray-300 hover:border-gray-400 text-gray-700 font-medium rounded-full transition-colors text-base">
          See Pricing
        </a>
      </div>
    </div>

    <!-- Screenshot Mockup -->
    <div class="relative max-w-5xl mx-auto">
      <div class="relative bg-white border border-gray-200 rounded-2xl shadow-xl overflow-hidden">
        <!-- Browser Chrome -->
        <div class="flex items-center gap-2 px-6 py-4 border-b border-gray-200 bg-gray-50">
          <div class="w-3 h-3 rounded-full bg-red-400/60"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-400/60"></div>
          <div class="w-3 h-3 rounded-full bg-green-400/60"></div>
          <span class="ml-3 text-gray-400 text-xs">checkout.mystore.com/checkout</span>
        </div>

        <!-- Checkout Mockup Content -->
        <div class="p-6 sm:p-8">
          <div class="grid lg:grid-cols-5 gap-8">
            <!-- Left: Checkout Form -->
            <div class="lg:col-span-3 space-y-5">
              <!-- Progress Bar Block -->
              <div class="flex items-center gap-3 mb-6">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-mint-500 text-white text-xs font-bold flex items-center justify-center">1</div>
                  <span class="text-xs font-medium text-gray-900">Info</span>
                </div>
                <div class="h-0.5 w-8 bg-mint-500"></div>
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-mint-500 text-white text-xs font-bold flex items-center justify-center">2</div>
                  <span class="text-xs font-medium text-gray-900">Shipping</span>
                </div>
                <div class="h-0.5 w-8 bg-gray-200"></div>
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-gray-200 text-gray-400 text-xs font-bold flex items-center justify-center">3</div>
                  <span class="text-xs font-medium text-gray-400">Payment</span>
                </div>
              </div>

              <!-- Form Fields -->
              <div class="grid grid-cols-2 gap-3">
                <div class="bg-gray-50 rounded-lg p-3">
                  <div class="text-[10px] text-gray-400 mb-1">First Name</div>
                  <div class="h-2 bg-gray-200 rounded w-3/4"></div>
                </div>
                <div class="bg-gray-50 rounded-lg p-3">
                  <div class="text-[10px] text-gray-400 mb-1">Last Name</div>
                  <div class="h-2 bg-gray-200 rounded w-2/3"></div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-3">
                <div class="text-[10px] text-gray-400 mb-1">Shipping Address</div>
                <div class="h-2 bg-gray-200 rounded w-5/6"></div>
              </div>

              <!-- Custom Field Block -->
              <div class="border border-mint-500/30 bg-mint-500/5 rounded-xl p-4">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                  </svg>
                  <span class="text-mint-600 text-xs font-semibold">Gift Message</span>
                </div>
                <div class="bg-white rounded-lg p-2 border border-gray-200">
                  <div class="h-2 bg-gray-100 rounded w-4/5 mb-1.5"></div>
                  <div class="h-2 bg-gray-100 rounded w-3/5"></div>
                </div>
              </div>

              <!-- Delivery Date Block -->
              <div class="bg-gray-50 rounded-lg p-3">
                <div class="text-[10px] text-gray-400 mb-1">Preferred Delivery Date</div>
                <div class="flex items-center gap-2">
                  <div class="h-2 bg-gray-200 rounded w-1/3"></div>
                  <svg class="w-3.5 h-3.5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              </div>
            </div>

            <!-- Right: Order Summary -->
            <div class="lg:col-span-2 space-y-4">
              <div class="font-heading font-semibold text-gray-900 text-sm">Order Summary</div>

              <!-- Product -->
              <div class="flex items-center gap-3 bg-gray-50 rounded-xl p-3">
                <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-xs font-medium text-gray-900">Premium Headphones</div>
                  <div class="text-[10px] text-gray-400">Qty: 1</div>
                </div>
                <span class="text-mint-600 font-semibold text-sm">$89.99</span>
              </div>

              <!-- Upsell Block -->
              <div class="border border-mint-500/30 bg-mint-500/5 rounded-xl p-4">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-mint-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-mint-600 text-xs font-semibold">Recommended for You</span>
                </div>
                <div class="text-xs text-gray-600">Add Carrying Case — <span class="text-mint-600 font-semibold">Save 25%</span></div>
              </div>

              <!-- Trust Badges Block -->
              <div class="bg-gray-50 rounded-xl p-4">
                <div class="flex items-center gap-3 justify-center">
                  <div class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    <span class="text-[10px] text-gray-500">Secure</span>
                  </div>
                  <div class="w-px h-4 bg-gray-200"></div>
                  <div class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                    </svg>
                    <span class="text-[10px] text-gray-500">Encrypted</span>
                  </div>
                  <div class="w-px h-4 bg-gray-200"></div>
                  <div class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    <span class="text-[10px] text-gray-500">30-Day Returns</span>
                  </div>
                </div>
              </div>

              <!-- Pay Button -->
              <button class="w-full bg-mint-500 text-white font-bold py-3 rounded-xl text-sm">
                Pay $89.99
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating Annotation Badges -->
      <div class="absolute -top-3 -left-3 sm:left-4 bg-white border border-gray-200 rounded-xl px-3 py-2 shadow-lg">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-mint-500 rounded-full"></div>
          <span class="text-xs font-medium text-gray-700">Progress Bar</span>
        </div>
      </div>

      <div class="absolute top-1/3 -right-3 sm:-right-4 bg-white border border-gray-200 rounded-xl px-3 py-2 shadow-lg">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-mint-500 rounded-full"></div>
          <span class="text-xs font-medium text-gray-700">Upsell Block</span>
        </div>
      </div>

      <div class="absolute -bottom-3 left-1/4 bg-white border border-gray-200 rounded-xl px-3 py-2 shadow-lg">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-mint-500 rounded-full"></div>
          <span class="text-xs font-medium text-gray-700">Custom Fields</span>
        </div>
      </div>

      <div class="absolute -bottom-3 right-1/4 bg-white border border-gray-200 rounded-xl px-3 py-2 shadow-lg">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-mint-500 rounded-full"></div>
          <span class="text-xs font-medium text-gray-700">Trust Badges</span>
        </div>
      </div>
    </div>
  </div>
</section>
