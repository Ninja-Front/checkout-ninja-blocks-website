---

---

<section class="relative min-h-screen pt-24 pb-16 flex items-center overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-mint-500/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-mint-500/10 border border-mint-500/20 rounded-full mb-6">
          <span class="w-2 h-2 bg-mint-400 rounded-full animate-pulse"></span>
          <span class="text-mint-300 text-sm font-medium">Trusted by 2,000+ Shopify stores</span>
        </div>

        <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
          Turn More Carts Into
          <span class="text-mint-400"> Customers</span>
        </h1>

        <p class="text-slate-400 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
          Checkout Ninja optimizes your Shopify checkout with one-page flows, smart upsells, and A/B testing — so you never lose a sale at the finish line.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#cta" class="inline-flex items-center justify-center px-8 py-3.5 bg-mint-500 hover:bg-mint-400 text-navy-950 font-semibold rounded-full transition-colors text-base">
            Install Free on Shopify
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-3.5 border border-navy-600 hover:border-slate-400 text-slate-200 font-medium rounded-full transition-colors text-base">
            See How It Works
          </a>
        </div>
      </div>

      <!-- Right: Checkout Mockup -->
      <div class="relative">
        <div class="relative bg-navy-900 border border-navy-700 rounded-2xl p-6 sm:p-8 shadow-2xl">
          <!-- Mockup Header -->
          <div class="flex items-center gap-2 mb-6">
            <div class="w-3 h-3 rounded-full bg-red-400/60"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/60"></div>
            <span class="ml-3 text-slate-400 text-xs">checkout.mystore.com</span>
          </div>

          <!-- Mockup Content -->
          <div class="space-y-4">
            <div class="flex items-center justify-between pb-4 border-b border-navy-700">
              <span class="font-heading font-semibold text-white">Express Checkout</span>
              <span class="text-mint-400 text-sm font-medium">Step 1 of 1</span>
            </div>

            <!-- Product -->
            <div class="flex items-center gap-4 bg-navy-800 rounded-xl p-4">
              <div class="w-14 h-14 bg-navy-700 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-mint-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="text-sm font-medium text-white">Premium Widget</div>
                <div class="text-xs text-slate-400">Qty: 1</div>
              </div>
              <span class="text-mint-400 font-semibold">$49.99</span>
            </div>

            <!-- Form Fields -->
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-navy-800 rounded-lg p-3">
                <div class="text-[10px] text-slate-400 mb-1">Email</div>
                <div class="h-2 bg-navy-700 rounded w-3/4"></div>
              </div>
              <div class="bg-navy-800 rounded-lg p-3">
                <div class="text-[10px] text-slate-400 mb-1">Phone</div>
                <div class="h-2 bg-navy-700 rounded w-2/3"></div>
              </div>
            </div>

            <div class="bg-navy-800 rounded-lg p-3">
              <div class="text-[10px] text-slate-400 mb-1">Shipping Address</div>
              <div class="h-2 bg-navy-700 rounded w-5/6"></div>
            </div>

            <!-- Upsell -->
            <div class="border border-mint-500/30 bg-mint-500/5 rounded-xl p-4">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4 text-mint-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
                </svg>
                <span class="text-mint-300 text-xs font-semibold">Smart Upsell</span>
              </div>
              <div class="text-xs text-slate-300">Add Premium Case — <span class="text-mint-400 font-semibold">Save 20%</span></div>
            </div>

            <!-- Pay Button -->
            <button class="w-full bg-mint-500 text-navy-950 font-bold py-3.5 rounded-xl text-sm">
              Pay $49.99
            </button>
          </div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-4 -right-4 bg-navy-900 border border-navy-700 rounded-xl px-4 py-3 shadow-xl">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-mint-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            <div>
              <div class="text-xs text-slate-400">Conversion Rate</div>
              <div class="text-mint-400 font-bold text-sm">+32%</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
