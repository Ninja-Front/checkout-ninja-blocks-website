---
const studies = [
  {
    store: "Headphone Zone",
    action: "Added trust badges, customer reviews, and gift message fields to their checkout",
    result: "Customers feel more confident completing purchases with visible trust signals at checkout.",
  },
  {
    store: "Lumebox",
    action: "Set up checkout validation rules to prevent incomplete orders",
    result: "Reduced support tickets from incomplete orders and improved fulfillment accuracy.",
  },
  {
    store: "Store Example",
    action: "Implemented checkout upsells and branded banners to increase average order value",
    result: "Saw measurable improvement in AOV with targeted product recommendations at checkout.",
  },
];
---

<section class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-14">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-4">
        Results from real stores
      </h2>
      <p class="text-gray-500 text-lg">
        See how Shopify Plus merchants are using Checkout Ninja to improve their checkout experience.
      </p>
    </div>

    <div class="space-y-0 border-l-2 border-mint-500/20 ml-4 lg:ml-8">
      {studies.map((study, i) => (
        <div class="relative pl-8 lg:pl-12 pb-12 last:pb-0">
          <div class="absolute -left-[9px] top-0 w-4 h-4 bg-mint-500 rounded-full border-2 border-white"></div>
          <div class="text-xs text-mint-600 font-semibold uppercase tracking-wider mb-2">
            {study.store}
          </div>
          <p class="text-gray-700 font-medium mb-2">
            {study.action}
          </p>
          <p class="text-gray-500 text-sm italic">
            "{study.result}"
          </p>
        </div>
      ))}
    </div>

    <div class="mt-10 ml-4 lg:ml-8 pl-8 lg:pl-12">
      <a href="/case-studies" class="inline-flex items-center gap-2 text-mint-600 font-medium text-sm hover:text-mint-700 transition-colors">
        Read more case studies
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
