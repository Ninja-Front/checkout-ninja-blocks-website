---
const problems = [
  {
    stat: "70.19%",
    label: "Cart Abandonment Rate",
    description: "Nearly 7 out of 10 shoppers leave without completing their purchase — most due to a broken checkout experience.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" /></svg>`,
  },
  {
    stat: "53%",
    label: "Bounce on Slow Load",
    description: "If your checkout takes more than 3 seconds to load, over half your visitors will leave before they even start.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    stat: "67%",
    label: "Mobile Carts Abandoned",
    description: "Mobile shoppers abandon at even higher rates. A clunky mobile checkout is revenue left on the table.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>`,
  },
];
---

<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-white mb-4">
        Why Stores Lose Sales at Checkout
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Your products are great. Your marketing works. But a poor checkout experience is silently killing your conversions.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {problems.map((problem) => (
        <div class="bg-navy-900 border border-navy-700 rounded-2xl p-8 text-center hover:border-navy-600 transition-colors">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-red-500/10 rounded-xl text-red-400 mb-5" set:html={problem.icon} />
          <div class="font-heading font-bold text-4xl text-white mb-2">{problem.stat}</div>
          <div class="text-mint-400 font-semibold text-sm uppercase tracking-wide mb-3">{problem.label}</div>
          <p class="text-slate-400 text-sm leading-relaxed">{problem.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
