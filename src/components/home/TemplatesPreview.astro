---
const templates = [
  { name: "Trust-Focused", description: "Trust badges, reviews, and secure checkout signals", color: "bg-emerald-50 border-emerald-100" },
  { name: "Upsell-Focused", description: "Product recommendations and bundle offers at checkout", color: "bg-amber-50 border-amber-100" },
  { name: "Custom Fields", description: "Gift messages, date pickers, and special instructions", color: "bg-sky-50 border-sky-100" },
  { name: "Full Suite", description: "A complete checkout with all block types configured", color: "bg-violet-50 border-violet-100" },
];
---

<section class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-5 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div class="lg:col-span-2 mb-10 lg:mb-0">
        <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-4">
          Don't want to start from scratch?
        </h2>
        <p class="text-gray-500 text-lg mb-6">
          Pick a pre-built template and customize it to match your store. Each template comes with pre-configured blocks ready to go.
        </p>
        <a href="/templates" class="inline-flex items-center gap-2 text-mint-600 font-medium hover:text-mint-700 transition-colors">
          Browse all templates
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <!-- Right: Template Grid -->
      <div class="lg:col-span-3 grid grid-cols-2 gap-4">
        {templates.map((tpl) => (
          <div class:list={["rounded-2xl border p-6 flex flex-col justify-between aspect-square", tpl.color]}>
            <div>
              <h3 class="font-heading font-semibold text-gray-900 mb-2">{tpl.name}</h3>
              <p class="text-gray-500 text-sm">{tpl.description}</p>
            </div>
            <div class="mt-4">
              <div class="flex gap-1">
                <div class="h-1.5 w-8 bg-gray-300/50 rounded-full"></div>
                <div class="h-1.5 w-12 bg-gray-300/50 rounded-full"></div>
                <div class="h-1.5 w-6 bg-gray-300/50 rounded-full"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
