---
const testimonials = [
  {
    quote: "Checkout Ninja made it so easy to add trust badges and custom fields. Our checkout completion rate improved noticeably within the first week.",
    name: "Raghav M.",
    store: "Headphone Zone",
  },
  {
    quote: "We tried other checkout apps but nothing came close to the flexibility here. The template system saved us hours of setup time.",
    name: "Alex T.",
    store: "Lumebox",
  },
  {
    quote: "The conditional visibility rules are a game changer. We show different content based on cart value and it's driven real results.",
    name: "Priya S.",
    store: "Verified Shopify Merchant",
  },
];
---

<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 text-center mb-14">
      What merchants say
    </h2>

    <!-- Featured large testimonial -->
    <div class="text-center mb-14 max-w-3xl mx-auto">
      <svg class="w-10 h-10 text-mint-500/30 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
      </svg>
      <blockquote class="font-heading text-2xl sm:text-3xl text-gray-900 leading-relaxed mb-6">
        "{testimonials[0].quote}"
      </blockquote>
      <div class="flex items-center justify-center gap-2">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map(() => (
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
      </div>
      <div class="mt-3">
        <span class="text-gray-900 font-semibold text-sm">{testimonials[0].name}</span>
        <span class="text-gray-400 text-sm"> · {testimonials[0].store}</span>
      </div>
    </div>

    <!-- Secondary testimonials -->
    <div class="grid md:grid-cols-2 gap-8 border-t border-gray-100 pt-14">
      {testimonials.slice(1).map((t) => (
        <div class="flex gap-4">
          <svg class="w-6 h-6 text-mint-500/20 shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
          </svg>
          <div>
            <p class="text-gray-700 leading-relaxed mb-3">"{t.quote}"</p>
            <div>
              <span class="text-gray-900 font-semibold text-sm">{t.name}</span>
              <span class="text-gray-400 text-sm"> · {t.store}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
