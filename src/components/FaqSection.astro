---
const faqs = [
  {
    question: "Does Checkout Ninja work with all Shopify plans?",
    answer: "Yes! Checkout Ninja works with all Shopify plans including Basic, Shopify, Advanced, and Plus. Some advanced customization features may require Shopify Plus for full checkout extensibility.",
  },
  {
    question: "Will it slow down my store?",
    answer: "Not at all. Checkout Ninja is built for performance. Our lightweight scripts load asynchronously and are optimized to keep your checkout loading in under 1 second. Most stores see faster checkout load times after installing.",
  },
  {
    question: "Can I customize the checkout design?",
    answer: "Absolutely. Our drag-and-drop editor lets you customize colors, fonts, layouts, button styles, and more — all without writing a single line of code. Your checkout will match your brand perfectly.",
  },
  {
    question: "How does the A/B testing work?",
    answer: "You can create multiple variations of your checkout (different layouts, copy, upsell offers) and split traffic between them. Our analytics dashboard shows you which version converts best with statistical confidence scores.",
  },
  {
    question: "Is there a free trial?",
    answer: "Yes! Our Starter plan is free forever with up to 100 orders per month. For the Growth and Scale plans, we offer a 14-day free trial with full access to all features. No credit card required to start.",
  },
  {
    question: "How do I get support?",
    answer: "We offer email support on all plans, with priority support on Growth and a dedicated account manager on Scale. Our average response time is under 2 hours during business hours. We also have extensive documentation and video tutorials.",
  },
];
---

<section id="faq" class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-4">
        Frequently Asked Questions
      </h2>
      <p class="text-gray-500 text-lg">
        Everything you need to know about Checkout Ninja.
      </p>
    </div>

    <div class="space-y-0 divide-y divide-gray-200">
      {faqs.map((faq) => (
        <details class="group py-5">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="font-heading font-semibold text-gray-900 text-base pr-8">{faq.question}</span>
            <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </summary>
          <p class="text-gray-500 text-sm leading-relaxed mt-3 pr-12">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
