---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const shopifyAppStoreUrl = "https://apps.shopify.com/checkout-ninja-blocks";

const plans = [
  {
    name: "Advanced",
    monthlyPrice: "$49",
    annualPrice: "$490",
    annualSavings: "save 17%",
    description: "Everything you need to customize your checkout with blocks",
    features: [
      "24 checkout blocks across 4 categories",
      "Unlimited blocks",
      "Pre-built templates",
      "Conditional block visibility (31 conditions)",
      "Drag-and-drop, no code",
    ],
    highlighted: false,
  },
  {
    name: "Deluxe",
    monthlyPrice: "$99",
    annualPrice: "$990",
    annualSavings: "save 17%",
    description: "Full control — blocks, rules, multi-language blocks, and API integrations",
    features: [
      "Everything in Advanced, plus:",
      "Checkout Rules (validation, API, quantity)",
      "Multi-language blocks for different markets",
      "Validate Address via API",
      "Gift Card Validation via API",
    ],
    highlighted: true,
    badge: "Recommended",
  },
];

const comparisonRows = [
  { feature: "Checkout Blocks", advanced: true, deluxe: true },
  { feature: "Unlimited Blocks", advanced: true, deluxe: true },
  { feature: "Templates", advanced: true, deluxe: true },
  { feature: "Conditional Visibility", advanced: true, deluxe: true },
  { feature: "Checkout Rules", advanced: false, deluxe: true },
  { feature: "API Validation", advanced: false, deluxe: true },
  { feature: "Quantity Rules", advanced: false, deluxe: true },
  { feature: "Multi-Language Blocks", advanced: false, deluxe: true },
  { feature: "Address Validation", advanced: false, deluxe: true },
  { feature: "Gift Card Validation", advanced: false, deluxe: true },
];

const faqs = [
  {
    question: "Is there a free trial?",
    answer: "Yes, 3 days on both plans. No credit card required.",
  },
  {
    question: "Can I switch plans later?",
    answer: "Yes, upgrade or downgrade anytime.",
  },
  {
    question: "What happens after the trial?",
    answer: "You'll be charged based on your selected plan. Cancel anytime.",
  },
  {
    question: "Do I need Shopify Plus?",
    answer: "Yes, Checkout Ninja works exclusively with Shopify Plus stores.",
  },
  {
    question: "Is there a setup fee?",
    answer: "No, install and start customizing immediately.",
  },
  {
    question: "Can I get a demo?",
    answer: 'Yes, <a href="/demo" class="text-mint-500 hover:text-mint-600 underline">book a demo</a> and we\'ll walk you through everything.',
  },
];
---

<BaseLayout
  title="Pricing — Checkout Ninja | Shopify Plus Checkout Customization"
  description="Simple pricing for powerful checkout customization. Advanced $49/mo for blocks, Deluxe $99/mo for blocks + rules + API integrations. 3-day free trial."
>
  <Navbar />
  <main class="pt-16">
    <!-- Section 1: Hero -->
    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-gray-900 mb-6">
          Simple Pricing, Powerful Checkout
        </h1>
        <p class="text-gray-500 text-lg sm:text-xl max-w-2xl mx-auto">
          Choose the plan that fits your store. Start with a 3-day free trial.
        </p>
      </div>
    </section>

    <!-- Section 2: Pricing Cards -->
    <section class="pb-16 lg:pb-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Monthly/Annual Toggle -->
        <div class="flex items-center justify-center gap-3 mb-12">
          <span id="monthly-label" class="text-sm font-semibold text-gray-900">Monthly</span>
          <button
            id="billing-toggle"
            type="button"
            role="switch"
            aria-checked="false"
            aria-label="Toggle annual billing"
            class="relative inline-flex h-7 w-12 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-gray-300 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-mint-500 focus-visible:ring-offset-2"
          >
            <span class="pointer-events-none inline-block h-6 w-6 transform rounded-full bg-white shadow-sm ring-0 transition-transform translate-x-0" id="toggle-dot"></span>
          </button>
          <span id="annual-label" class="text-sm font-medium text-gray-400">Annual</span>
        </div>

        <!-- Cards -->
        <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
          {plans.map((plan) => (
            <div class:list={[
              "relative rounded-2xl p-8 transition-all",
              plan.highlighted
                ? "bg-white border-2 border-mint-500 shadow-lg shadow-mint-500/10"
                : "bg-white border border-gray-200 shadow-sm"
            ]}>
              {plan.badge && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-mint-500 text-white text-xs font-bold rounded-full">
                  {plan.badge}
                </div>
              )}

              <div class="mb-6">
                <h3 class="font-heading font-semibold text-lg text-gray-900 mb-2">{plan.name}</h3>
                <div class="flex items-baseline gap-1 mb-1">
                  <span class="font-heading font-bold text-4xl text-gray-900 price-monthly">{plan.monthlyPrice}</span>
                  <span class="text-gray-400 text-sm price-monthly">/month</span>
                  <span class="font-heading font-bold text-4xl text-gray-900 price-annual hidden">{plan.annualPrice}</span>
                  <span class="text-gray-400 text-sm price-annual hidden">/year</span>
                </div>
                <p class="text-mint-600 text-sm font-medium price-annual hidden">({plan.annualSavings})</p>
                <p class="text-gray-500 text-sm mt-3">{plan.description}</p>
              </div>

              <ul class="space-y-3 mb-8">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3 text-sm">
                    <svg class="w-5 h-5 text-mint-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    <span class="text-gray-600">{feature}</span>
                  </li>
                ))}
              </ul>

              <a
                href={shopifyAppStoreUrl}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  "block w-full text-center py-3 rounded-full font-semibold text-sm transition-colors",
                  plan.highlighted
                    ? "bg-mint-500 hover:bg-mint-600 text-white"
                    : "border border-gray-300 hover:border-gray-400 text-gray-700"
                ]}
              >
                Start Free Trial
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 3: Key Differences -->
    <section class="py-16 lg:py-24 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-4">
            Compare Plans
          </h2>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-4 px-6 text-sm font-semibold text-gray-900">Feature</th>
                <th class="text-center py-4 px-6 text-sm font-semibold text-gray-900">Advanced</th>
                <th class="text-center py-4 px-6 text-sm font-semibold text-mint-600">Deluxe</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row, i) => (
                <tr class:list={[i < comparisonRows.length - 1 && "border-b border-gray-100"]}>
                  <td class="py-3.5 px-6 text-sm text-gray-700">{row.feature}</td>
                  <td class="py-3.5 px-6 text-center">
                    {row.advanced ? (
                      <svg class="w-5 h-5 text-mint-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                    ) : (
                      <span class="text-gray-300">—</span>
                    )}
                  </td>
                  <td class="py-3.5 px-6 text-center">
                    {row.deluxe ? (
                      <svg class="w-5 h-5 text-mint-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                    ) : (
                      <span class="text-gray-300">—</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Section 4: FAQ -->
    <section class="py-16 lg:py-24">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 lg:mb-16">
          <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-4">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-0 divide-y divide-gray-200">
          {faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex items-center justify-between cursor-pointer list-none">
                <span class="font-heading font-semibold text-gray-900 text-base pr-8">{faq.question}</span>
                <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
              </summary>
              <p class="text-gray-500 text-sm leading-relaxed mt-3 pr-12" set:html={faq.answer} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 5: Social Proof Strip -->
    <section class="py-12 bg-gray-50 border-y border-gray-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-12 text-center">
          <!-- Star Rating -->
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm text-gray-600 font-medium">5.0 on Shopify App Store</span>
          </div>

          <div class="hidden md:block w-px h-8 bg-gray-300"></div>

          <!-- Built for Shopify Plus -->
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            <span class="text-sm text-gray-600 font-medium">Built for Shopify Plus</span>
          </div>

          <div class="hidden md:block w-px h-8 bg-gray-300"></div>

          <!-- Trust Line -->
          <span class="text-sm text-gray-600 font-medium">Trusted by brands across 15+ countries</span>
        </div>
      </div>
    </section>

    <!-- Section 6: Bottom CTA -->
    <section class="py-16 lg:py-24 relative overflow-hidden">
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-[800px] h-[400px] bg-mint-500/5 rounded-full blur-3xl"></div>
      </div>

      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
        <h2 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-gray-900 mb-6">
          Not Sure Which Plan? Start Your Free Trial
        </h2>
        <p class="text-gray-500 text-lg sm:text-xl mb-10 max-w-2xl mx-auto">
          Try Checkout Ninja free for 3 days. No commitment.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={shopifyAppStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-10 py-4 bg-mint-500 hover:bg-mint-600 text-white font-bold rounded-full transition-colors text-base"
          >
            Start Free Trial
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="/demo" class="inline-flex items-center justify-center px-10 py-4 border border-gray-300 hover:border-gray-400 text-gray-700 font-medium rounded-full transition-colors text-base">
            Book a Demo
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const toggle = document.getElementById('billing-toggle');
  const dot = document.getElementById('toggle-dot');
  const monthlyLabel = document.getElementById('monthly-label');
  const annualLabel = document.getElementById('annual-label');
  const monthlyEls = document.querySelectorAll('.price-monthly');
  const annualEls = document.querySelectorAll('.price-annual');

  let isAnnual = false;

  toggle?.addEventListener('click', () => {
    isAnnual = !isAnnual;
    toggle.setAttribute('aria-checked', String(isAnnual));

    if (isAnnual) {
      toggle.classList.remove('bg-gray-300');
      toggle.classList.add('bg-mint-500');
      dot?.classList.remove('translate-x-0');
      dot?.classList.add('translate-x-5');
      monthlyLabel?.classList.remove('text-gray-900', 'font-semibold');
      monthlyLabel?.classList.add('text-gray-400', 'font-medium');
      annualLabel?.classList.remove('text-gray-400', 'font-medium');
      annualLabel?.classList.add('text-gray-900', 'font-semibold');
      monthlyEls.forEach(el => el.classList.add('hidden'));
      annualEls.forEach(el => el.classList.remove('hidden'));
    } else {
      toggle.classList.remove('bg-mint-500');
      toggle.classList.add('bg-gray-300');
      dot?.classList.remove('translate-x-5');
      dot?.classList.add('translate-x-0');
      monthlyLabel?.classList.remove('text-gray-400', 'font-medium');
      monthlyLabel?.classList.add('text-gray-900', 'font-semibold');
      annualLabel?.classList.remove('text-gray-900', 'font-semibold');
      annualLabel?.classList.add('text-gray-400', 'font-medium');
      monthlyEls.forEach(el => el.classList.remove('hidden'));
      annualEls.forEach(el => el.classList.add('hidden'));
    }
  });
</script>
