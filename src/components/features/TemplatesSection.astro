---
import { getCollection } from 'astro:content';

const entries = await getCollection('templates');
---

<section class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 mb-4">
        Launch in Minutes
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        Don't start from scratch — pick a ready-made checkout template and go live instantly
      </p>
    </div>

    <!-- Template Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {entries.map((entry) => (
        <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <!-- Mini Preview Mockup -->
          <div class="bg-gray-100 p-4">
            <div class="bg-white rounded-lg border border-gray-200 p-3">
              <!-- Mini browser chrome -->
              <div class="flex items-center gap-1 mb-2.5">
                <div class="w-1.5 h-1.5 rounded-full bg-red-400/40"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-yellow-400/40"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-green-400/40"></div>
                <div class="h-1 bg-gray-100 rounded ml-1.5 w-16"></div>
              </div>
              <!-- Simplified checkout mockup -->
              <div class="space-y-2">
                <div class="h-1.5 bg-gray-100 rounded w-1/2"></div>
                <div class="grid grid-cols-2 gap-1.5">
                  <div class="h-5 bg-gray-50 rounded"></div>
                  <div class="h-5 bg-gray-50 rounded"></div>
                </div>
                <div class="h-5 bg-gray-50 rounded"></div>
                <div class="h-6 bg-mint-500/20 rounded"></div>
              </div>
            </div>
          </div>

          <!-- Template Info -->
          <div class="p-5">
            <h3 class="font-heading font-semibold text-gray-900 mb-1">{entry.data.name}</h3>
            <p class="text-gray-500 text-sm">{entry.data.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a href="/templates" class="inline-flex items-center gap-2 text-mint-600 hover:text-mint-700 font-semibold transition-colors">
        Browse All Templates
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
