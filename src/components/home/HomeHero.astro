---

---

<section class="relative min-h-screen pt-24 pb-16 flex items-center overflow-hidden">
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-mint-500/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-3 px-5 py-2 bg-white border border-gray-200 rounded-full shadow-sm mb-8">
          <svg class="w-5 h-5 text-mint-500" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
          <span class="text-sm font-medium text-gray-700">Built for Shopify Plus</span>
        </div>

        <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6 text-gray-900">
          Build a Better<br />
          <span class="text-mint-500">Checkout</span>
        </h1>

        <p class="text-gray-500 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
          Shopify Plus gives you a checkout. Checkout Ninja lets you make it yours — with trust badges, custom fields, upsells, validation rules, templates, and 20+ more block types. No code required.
        </p>

        <div class="flex items-center justify-center lg:justify-start gap-2 mb-8">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm font-medium text-gray-600">5.0 on the Shopify App Store</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="https://apps.shopify.com/checkout-ninja" class="inline-flex items-center justify-center px-8 py-3.5 bg-mint-500 hover:bg-mint-600 text-white font-semibold rounded-full transition-colors text-base">
            Install on Shopify
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 border border-gray-300 hover:border-gray-400 text-gray-700 font-medium rounded-full transition-colors text-base">
            Book a Demo
          </a>
        </div>
      </div>

      <!-- Right: Checkout Mockup -->
      <div class="relative">
        <div class="relative bg-white border border-gray-200 rounded-2xl p-6 sm:p-8 shadow-xl">
          <!-- Mockup Header -->
          <div class="flex items-center gap-2 mb-6">
            <div class="w-3 h-3 rounded-full bg-red-400/60"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/60"></div>
            <span class="ml-3 text-gray-400 text-xs">checkout.mystore.com</span>
          </div>

          <!-- Mockup Content -->
          <div class="space-y-4">
            <div class="flex items-center justify-between pb-4 border-b border-gray-200">
              <span class="font-heading font-semibold text-gray-900">Shopify Plus Checkout</span>
              <span class="text-mint-500 text-sm font-medium">Customized</span>
            </div>

            <!-- Trust Badge Row -->
            <div class="flex items-center gap-3 bg-mint-500/5 border border-mint-500/20 rounded-xl p-3">
              <svg class="w-5 h-5 text-mint-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
              <div class="flex gap-2 text-xs text-gray-500">
                <span class="bg-white px-2 py-1 rounded border border-gray-100">Secure Checkout</span>
                <span class="bg-white px-2 py-1 rounded border border-gray-100">SSL Encrypted</span>
                <span class="bg-white px-2 py-1 rounded border border-gray-100">Money-Back</span>
              </div>
            </div>

            <!-- Product -->
            <div class="flex items-center gap-4 bg-gray-50 rounded-xl p-4">
              <div class="w-14 h-14 bg-gray-100 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="text-sm font-medium text-gray-900">Premium Widget</div>
                <div class="text-xs text-gray-400">Qty: 1</div>
              </div>
              <span class="text-mint-600 font-semibold">$49.99</span>
            </div>

            <!-- Custom Field -->
            <div class="bg-gray-50 rounded-lg p-3">
              <div class="text-[10px] text-gray-400 mb-1">Gift Message (Custom Field)</div>
              <div class="h-2 bg-gray-200 rounded w-4/5"></div>
            </div>

            <!-- Upsell -->
            <div class="border border-mint-500/30 bg-mint-500/5 rounded-xl p-4">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4 text-mint-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
                </svg>
                <span class="text-mint-600 text-xs font-semibold">Checkout Upsell</span>
              </div>
              <div class="text-xs text-gray-600">Add Premium Case — <span class="text-mint-600 font-semibold">Save 20%</span></div>
            </div>

            <!-- Pay Button -->
            <button class="w-full bg-mint-500 text-white font-bold py-3.5 rounded-xl text-sm">
              Pay $49.99
            </button>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="absolute -bottom-4 -right-4 bg-white border border-gray-200 rounded-xl px-4 py-3 shadow-lg">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
            </svg>
            <div>
              <div class="text-xs text-gray-400">Block Types</div>
              <div class="text-mint-600 font-bold text-sm">24+</div>
            </div>
          </div>
        </div>

        <div class="absolute -top-3 -left-3 bg-white border border-gray-200 rounded-xl px-4 py-3 shadow-lg hidden sm:flex">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <div>
              <div class="text-xs text-gray-400">Setup</div>
              <div class="text-mint-600 font-bold text-sm">No Code</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
