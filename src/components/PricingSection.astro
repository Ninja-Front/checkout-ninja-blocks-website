---
const plans = [
  {
    name: "Starter",
    price: "Free",
    period: "",
    description: "Perfect for new stores getting started with checkout optimization.",
    features: [
      "Basic checkout customization",
      "Up to 100 orders/month",
      "Mobile-optimized checkout",
      "Email support",
    ],
    cta: "Get Started Free",
    highlighted: false,
  },
  {
    name: "Growth",
    price: "$29",
    period: "/mo",
    description: "For growing stores that want to maximize every checkout.",
    features: [
      "Full checkout customization",
      "Up to 2,000 orders/month",
      "Smart upsells & cross-sells",
      "A/B testing",
      "Real-time analytics",
      "Priority support",
    ],
    cta: "Start Free Trial",
    highlighted: true,
    badge: "Most Popular",
  },
  {
    name: "Scale",
    price: "$99",
    period: "/mo",
    description: "For high-volume stores that need enterprise-grade features.",
    features: [
      "Everything in Growth",
      "Unlimited orders",
      "Custom integrations",
      "Advanced analytics & reports",
      "Dedicated account manager",
      "SLA guarantee",
    ],
    cta: "Contact Sales",
    highlighted: false,
  },
];
---

<section id="pricing" class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-white mb-4">
        Simple, Transparent Pricing
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Start free and scale as you grow. No hidden fees, no long-term contracts.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 items-start">
      {plans.map((plan) => (
        <div class:list={[
          "relative rounded-2xl p-8 transition-all",
          plan.highlighted
            ? "bg-navy-800 border-2 border-mint-500 scale-[1.02] shadow-lg shadow-mint-500/10"
            : "bg-navy-900 border border-navy-700"
        ]}>
          {plan.badge && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-mint-500 text-navy-950 text-xs font-bold rounded-full">
              {plan.badge}
            </div>
          )}

          <div class="mb-6">
            <h3 class="font-heading font-semibold text-lg text-white mb-2">{plan.name}</h3>
            <div class="flex items-baseline gap-1 mb-3">
              <span class="font-heading font-bold text-4xl text-white">{plan.price}</span>
              {plan.period && <span class="text-slate-400 text-sm">{plan.period}</span>}
            </div>
            <p class="text-slate-400 text-sm">{plan.description}</p>
          </div>

          <ul class="space-y-3 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-mint-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span class="text-slate-300">{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="#cta"
            class:list={[
              "block w-full text-center py-3 rounded-full font-semibold text-sm transition-colors",
              plan.highlighted
                ? "bg-mint-500 hover:bg-mint-400 text-navy-950"
                : "border border-navy-600 hover:border-slate-400 text-slate-200"
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
