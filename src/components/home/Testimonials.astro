---
const testimonials = [
  {
    quote: "Checkout Ninja made it so easy to add trust badges and custom fields. Our checkout completion rate improved noticeably within the first week.",
    name: "Raghav M.",
    store: "Headphone Zone",
  },
  {
    quote: "We tried other checkout apps but nothing came close to the flexibility here. The template system saved us hours of setup time.",
    name: "Alex T.",
    store: "Lumebox",
  },
  {
    quote: "The conditional visibility rules are a game changer. We show different content based on cart value and it's driven real results.",
    name: "Priya S.",
    store: "Verified Shopify Merchant",
  },
];
---

<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gray-900 text-center mb-12">
      What merchants say
    </h2>

    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-700 text-sm leading-relaxed mb-6">"{t.quote}"</p>
          <div>
            <div class="text-gray-900 font-semibold text-sm">{t.name}</div>
            <div class="text-gray-400 text-xs">{t.store}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
